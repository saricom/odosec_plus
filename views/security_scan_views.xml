<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- SCAN FINDING — TREE (embedded in scan form) -->
    <record id="view_scan_finding_list_inline" model="ir.ui.view">
      <field name="name">odosec.scan.finding.list.inline</field>
      <field name="model">odosec.scan.finding</field>
      <field name="arch" type="xml">
        <list string="Findings" create="false" delete="false"
              decoration-danger="severity == 'critical'"
              decoration-warning="severity == 'high'"
              decoration-info="severity == 'medium'"
              decoration-muted="is_resolved">
          <field name="severity" string="Severity" widget="badge"
                 decoration-danger="severity == 'critical'"
                 decoration-warning="severity == 'high'"
                 decoration-info="severity == 'medium'"
                 decoration-muted="is_resolved"/>
          <field name="category" string="Category"/>
          <field name="title" string="Finding"/>
          <field name="affected_ref" string="Affected Object" optional="show"/>
          <field name="is_resolved" string="Resolved" widget="boolean"/>
        </list>
      </field>
    </record>

    <!-- SCAN FINDING — FORM -->
    <record id="view_scan_finding_form" model="ir.ui.view">
      <field name="name">odosec.scan.finding.form</field>
      <field name="model">odosec.scan.finding</field>
      <field name="arch" type="xml">
        <form string="Security Finding">
          <header>
            <button name="action_mark_resolved" type="object"
                    string="Mark Resolved" class="btn-success"
                    invisible="is_resolved"
                    groups="odosec_plus.group_odosec_analyst"/>
          </header>
          <sheet>
            <group>
              <group>
                <field name="severity" readonly="1" widget="badge"
                       decoration-danger="severity == 'critical'"
                       decoration-warning="severity == 'high'"/>
                <field name="category"     readonly="1"/>
                <field name="affected_ref" readonly="1"/>
                <field name="is_resolved"/>
              </group>
              <group>
                <field name="scan_id" readonly="1"/>
              </group>
            </group>
            <group string="Finding Description">
              <field name="title"  readonly="1" nolabel="1"/>
            </group>
            <group string="Technical Detail">
              <field name="detail" readonly="1" nolabel="1"/>
            </group>
            <group string="Recommended Remediation">
              <field name="remediation" readonly="1" nolabel="1"/>
            </group>
            <group string="Resolution Notes" invisible="not is_resolved">
              <field name="resolve_note" nolabel="1"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- SECURITY SCAN — TREE -->
    <record id="view_security_scan_list" model="ir.ui.view">
      <field name="name">odosec.security.scan.list</field>
      <field name="model">odosec.security.scan</field>
      <field name="arch" type="xml">
        <list string="Security Scans" create="false"
              decoration-danger="critical_count &gt; 0"
              decoration-warning="high_count &gt; 0 and critical_count == 0"
              decoration-success="state == 'done' and risk_score == 0">
          <field name="display_ref" string="Scan Reference"/>
          <field name="scan_date" string="Date"/>
          <field name="scan_type" string="Type"/>
          <field name="triggered_by" string="Triggered By"/>
          <field name="state" string="Status" widget="badge"
                 decoration-success="state == 'done'"
                 decoration-danger="state == 'error'"
                 decoration-warning="state == 'running'"/>
          <field name="risk_score" string="Risk Score"
                 decoration-danger="risk_score &gt;= 50"
                 decoration-warning="risk_score &gt;= 20"/>
          <field name="critical_count" string="Critical" optional="show"/>
          <field name="high_count"     string="High"     optional="show"/>
          <field name="medium_count"   string="Medium"   optional="hide"/>
          <field name="total_findings" string="Total"    optional="show"/>
          <field name="duration_sec"   string="Duration" optional="hide"/>
        </list>
      </field>
    </record>

    <!-- SECURITY SCAN — FORM -->
    <record id="view_security_scan_form" model="ir.ui.view">
      <field name="name">odosec.security.scan.form</field>
      <field name="model">odosec.security.scan</field>
      <field name="arch" type="xml">
        <form string="Security Scan" create="false">
          <header>
            <field name="state" widget="statusbar"
                   statusbar_visible="running,done,error"/>
          </header>
          <sheet>
            <div class="oe_title">
              <h1><field name="display_ref" readonly="1"/></h1>
            </div>
            <!-- Risk Score Badge -->
            <div class="alert alert-danger" role="alert"
                 invisible="risk_score &lt; 50">
              <strong>🚨 Critical Risk Score: <field name="risk_score" readonly="1"/></strong>
              — Immediate remediation required.
            </div>
            <div class="alert alert-warning" role="alert"
                 invisible="risk_score &lt; 20 or risk_score &gt;= 50">
              <strong>⚠️ Elevated Risk Score: <field name="risk_score" readonly="1"/></strong>
              — Review and address open findings.
            </div>
            <group>
              <group string="Scan Metadata">
                <field name="scan_date"    readonly="1"/>
                <field name="scan_type"    readonly="1"/>
                <field name="triggered_by" readonly="1"/>
                <field name="duration_sec" readonly="1"/>
              </group>
              <group string="Finding Summary">
                <field name="critical_count" readonly="1"/>
                <field name="high_count"     readonly="1"/>
                <field name="medium_count"   readonly="1"/>
                <field name="low_count"      readonly="1"/>
                <field name="total_findings" readonly="1"/>
              </group>
            </group>
            <group string="Error" invisible="state != 'error'">
              <field name="error_msg" readonly="1" nolabel="1"/>
            </group>
            <notebook>
              <page string="All Findings" name="findings">
                <field name="finding_ids" readonly="1"
                       context="{'default_scan_id': active_id}"
                       mode="list">
                  <list>
                    <field name="severity" widget="badge"
                           decoration-danger="severity == 'critical'"
                           decoration-warning="severity == 'high'"
                           decoration-info="severity == 'medium'"/>
                    <field name="category"/>
                    <field name="title"/>
                    <field name="affected_ref"/>
                    <field name="is_resolved" widget="boolean"/>
                  </list>
                </field>
              </page>
              <page string="Critical &amp; High" name="critical_high">
                <field name="finding_ids" readonly="1"
                       domain="[('severity','in',['critical','high']),('is_resolved','=',False)]"
                       mode="list">
                  <list>
                    <field name="severity" widget="badge"
                           decoration-danger="severity == 'critical'"
                           decoration-warning="severity == 'high'"/>
                    <field name="category"/>
                    <field name="title"/>
                    <field name="affected_ref"/>
                    <field name="remediation"/>
                  </list>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <!-- SEARCH -->
    <record id="view_security_scan_search" model="ir.ui.view">
      <field name="name">odosec.security.scan.search</field>
      <field name="model">odosec.security.scan</field>
      <field name="arch" type="xml">
        <search string="Search Scans">
          <field name="scan_type"/>
          <filter name="f_done"  string="Completed" domain="[('state','=','done')]"/>
          <filter name="f_error" string="Failed"    domain="[('state','=','error')]"/>
          <filter name="f_crit"  string="Has Critical Findings"
                  domain="[('critical_count','&gt;',0)]"/>
          <group string="Group By">
            <filter name="gb_type" string="Scan Type"
                    context="{'group_by': 'scan_type'}"/>
            <filter name="gb_date" string="Date"
                    context="{'group_by': 'scan_date:day'}"/>
          </group>
        </search>
      </field>
    </record>

    <!-- SERVER ACTION: Run Scan -->
    <record id="action_odosec_run_scan" model="ir.actions.server">
      <field name="name">OdoSec Plus: Run Full Security Scan</field>
      <field name="model_id" ref="model_odosec_security_scan"/>
      <field name="binding_model_id" ref="model_odosec_security_scan"/>
      <field name="state">code</field>
      <field name="code">
scan = model.action_run_scan(scan_type='full')
action = {
    'type': 'ir.actions.act_window',
    'res_model': 'odosec.security.scan',
    'res_id': scan.id,
    'view_mode': 'form',
    'target': 'current',
}
      </field>
      <field name="groups_id" eval="[(4, ref('odosec_plus.group_odosec_analyst'))]"/>
    </record>

    <!-- WINDOW ACTION -->
    <record id="action_odosec_security_scan" model="ir.actions.act_window">
      <field name="name">Security Scans</field>
      <field name="res_model">odosec.security.scan</field>
      <field name="view_mode">list,form</field>
      <field name="search_view_id" ref="view_security_scan_search"/>
      <field name="context">{'create': False}</field>
    </record>

  </data>
</odoo>
