<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- ══════════════════════════════════════════════════════
         LIST VIEW (Odoo 19: <list> replaces <tree>)
    ══════════════════════════════════════════════════════ -->
    <record id="view_odosec_audit_log_list" model="ir.ui.view">
      <field name="name">odosec.audit.log.list</field>
      <field name="model">odosec.audit.log</field>
      <field name="arch" type="xml">
        <list string="Audit Logs"
              create="false" edit="false" delete="false"
              decoration-danger="action_type == 'unlink'"
              decoration-warning="action_type in ('login_failed', 'export')"
              decoration-success="action_type == 'create'"
              decoration-info="action_type == 'login'">
          <field name="timestamp"   string="Timestamp"   optional="show"/>
          <field name="user_name"   string="User"        optional="show"/>
          <field name="model_name"  string="Model"       optional="show"/>
          <field name="record_id"   string="Rec ID"      optional="show"/>
          <field name="action_type" string="Action"
                 widget="badge"
                 decoration-danger="action_type in ('unlink', 'login_failed')"
                 decoration-warning="action_type == 'export'"
                 decoration-success="action_type == 'create'"
                 decoration-info="action_type in ('login', 'read')"
                 decoration-muted="action_type == 'write'"/>
          <field name="ip_address"  string="IP Address"  optional="show"/>
          <field name="integrity_ok" string="Hash OK"    widget="boolean" optional="hide"/>
          <field name="tamper_hash"  string="Hash"       optional="hide"/>
        </list>
      </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         FORM VIEW
    ══════════════════════════════════════════════════════ -->
    <record id="view_odosec_audit_log_form" model="ir.ui.view">
      <field name="name">odosec.audit.log.form</field>
      <field name="model">odosec.audit.log</field>
      <field name="arch" type="xml">
        <form string="Audit Log Entry" create="false" edit="false">
          <header>
            <button name="action_verify_integrity" type="object"
                    string="Verify Integrity" class="btn-secondary"
                    groups="odosec_plus.group_odosec_analyst"/>
          </header>
          <sheet>
            <div class="oe_title">
              <h1>
                <field name="display_name_computed" readonly="1"/>
              </h1>
            </div>
            <group>
              <group string="Event Identity">
                <field name="action_type" readonly="1" widget="badge"/>
                <field name="user_id"     readonly="1"/>
                <field name="timestamp"   readonly="1"/>
                <field name="ip_address"  readonly="1"/>
                <field name="session_id"  readonly="1"/>
              </group>
              <group string="Target Record">
                <field name="model_name"   readonly="1"/>
                <field name="record_id"    readonly="1"/>
                <field name="integrity_ok" readonly="1" widget="boolean_toggle"/>
                <field name="tamper_hash"  readonly="1"/>
              </group>
            </group>
            <notebook>
              <page string="Value Changes" name="values">
                <group>
                  <field name="old_values" readonly="1" widget="code"
                         invisible="action_type in ('create', 'login', 'login_failed')"/>
                  <field name="new_values" readonly="1" widget="code"
                         invisible="action_type in ('unlink', 'login', 'login_failed')"/>
                </group>
              </page>
              <page string="Context" name="context">
                <group>
                  <field name="additional_info" readonly="1"/>
                </group>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         PIVOT VIEW
    ══════════════════════════════════════════════════════ -->
    <record id="view_odosec_audit_log_pivot" model="ir.ui.view">
      <field name="name">odosec.audit.log.pivot</field>
      <field name="model">odosec.audit.log</field>
      <field name="arch" type="xml">
        <pivot string="Audit Analytics" disable_linking="false">
          <field name="model_name"  type="row"/>
          <field name="action_type" type="col"/>
          <field name="id"          type="measure" string="Count"/>
        </pivot>
      </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         SEARCH VIEW  — FIX: use context_today() for dynamic date filters
    ══════════════════════════════════════════════════════ -->
    <record id="view_odosec_audit_log_search" model="ir.ui.view">
      <field name="name">odosec.audit.log.search</field>
      <field name="model">odosec.audit.log</field>
      <field name="arch" type="xml">
        <search string="Search Audit Logs">
          <field name="user_name"   string="User"/>
          <field name="model_name"  string="Model"/>
          <field name="ip_address"  string="IP Address"/>
          <field name="action_type" string="Action Type"/>
          <field name="record_id"   string="Record ID"
                 filter_domain="[('record_id','=',self)]"/>

          <!-- Quick filters by action -->
          <filter name="f_create"       string="Creates"
                  domain="[('action_type','=','create')]"/>
          <filter name="f_write"        string="Updates"
                  domain="[('action_type','=','write')]"/>
          <filter name="f_delete"       string="Deletions"
                  domain="[('action_type','=','unlink')]"/>
          <filter name="f_failed_login" string="Failed Logins"
                  domain="[('action_type','=','login_failed')]"/>
          <filter name="f_export"       string="Exports"
                  domain="[('action_type','=','export')]"/>
          <separator/>
          <!-- FIX: Dynamic date filters using context_today() -->
          <filter name="f_today"  string="Today"
                  domain="[('timestamp','&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
          <filter name="f_7d"     string="Last 7 Days"
                  domain="[('timestamp','&gt;=', (context_today() - relativedelta(days=7)).strftime('%Y-%m-%d 00:00:00'))]"/>
          <filter name="f_30d"    string="Last 30 Days"
                  domain="[('timestamp','&gt;=', (context_today() - relativedelta(days=30)).strftime('%Y-%m-%d 00:00:00'))]"/>
          <separator/>
          <filter name="f_integrity" string="Hash Mismatch (Tampered)"
                  domain="[('integrity_ok','=',False)]"/>

          <!-- Group-by options -->
          <group expand="0" string="Group By">
            <filter name="gb_user"   string="User"
                    context="{'group_by': 'user_id'}"/>
            <filter name="gb_model"  string="Model"
                    context="{'group_by': 'model_name'}"/>
            <filter name="gb_action" string="Action Type"
                    context="{'group_by': 'action_type'}"/>
            <filter name="gb_day"    string="Day"
                    context="{'group_by': 'timestamp:day'}"/>
            <filter name="gb_week"   string="Week"
                    context="{'group_by': 'timestamp:week'}"/>
            <filter name="gb_month"  string="Month"
                    context="{'group_by': 'timestamp:month'}"/>
          </group>
        </search>
      </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         ACTION
    ══════════════════════════════════════════════════════ -->
    <record id="action_odosec_audit_log" model="ir.actions.act_window">
      <field name="name">Audit Logs</field>
      <field name="res_model">odosec.audit.log</field>
      <field name="view_mode">list,form,pivot</field>
      <field name="search_view_id" ref="view_odosec_audit_log_search"/>
      <field name="context">{'create': False, 'search_default_f_7d': 1}</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          No audit log entries yet.
        </p>
        <p>
          Audit logs are automatically generated when users create, update, or delete records.
        </p>
      </field>
    </record>

  </data>
</odoo>
