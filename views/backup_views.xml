<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- TREE -->
    <record id="view_odosec_backup_list" model="ir.ui.view">
      <field name="name">odosec.backup.manager.list</field>
      <field name="model">odosec.backup.manager</field>
      <field name="arch" type="xml">
        <list string="Backups" create="false"
              decoration-success="state == 'done'"
              decoration-danger="state == 'failed'"
              decoration-warning="state == 'running'">
          <field name="name" string="Backup Name"/>
          <field name="create_date" string="Triggered At"/>
          <field name="triggered_by" string="By"/>
          <field name="state" string="Status" widget="badge"
                 decoration-success="state == 'done'"
                 decoration-danger="state == 'failed'"
                 decoration-warning="state == 'running'"/>
          <field name="backup_size" string="Size (MB)" digits="[8,2]"/>
          <field name="duration_sec" string="Duration (s)" optional="hide"/>
        </list>
      </field>
    </record>

    <!-- FORM -->
    <record id="view_odosec_backup_form" model="ir.ui.view">
      <field name="name">odosec.backup.manager.form</field>
      <field name="model">odosec.backup.manager</field>
      <field name="arch" type="xml">
        <form string="Backup Record">
          <header>
            <button name="action_download" type="object"
                    string="⬇ Download Encrypted Backup"
                    class="btn-primary"
                    invisible="state != 'done'"
                    groups="base.group_system"/>
            <button name="action_delete_file" type="object"
                    string="Delete File from Disk"
                    class="btn-danger"
                    invisible="state != 'done'"
                    confirm="This will permanently delete the backup file from disk. Are you sure?"
                    groups="base.group_system"/>
            <field name="state" widget="statusbar"
                   statusbar_visible="pending,running,done"/>
          </header>
          <sheet>
            <div class="oe_title">
              <h1><field name="name" readonly="1"/></h1>
            </div>
            <group>
              <group string="Backup Details">
                <field name="create_date"  readonly="1"/>
                <field name="triggered_by" readonly="1"/>
                <field name="backup_size"  readonly="1" digits="[8,2]"/>
                <field name="duration_sec" readonly="1"/>
              </group>
              <group string="Storage">
                <field name="file_path" readonly="1"/>
                <field name="can_download" readonly="1" widget="boolean_toggle"/>
              </group>
            </group>
            <group string="Error Details" invisible="state != 'failed'">
              <field name="error_msg" readonly="1" nolabel="1"/>
            </group>
            <group string="Notes">
              <field name="notes" nolabel="1"
                     groups="odosec_plus.group_odosec_admin"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- ACTION: Trigger new backup (server action button) -->
    <record id="action_odosec_trigger_backup" model="ir.actions.server">
      <field name="name">OdoSec Plus: Trigger Database Backup</field>
      <field name="model_id" ref="model_odosec_backup_manager"/>
      <field name="binding_model_id" ref="model_odosec_backup_manager"/>
      <field name="state">code</field>
      <field name="code">action = model.action_trigger_backup()</field>
      <field name="groups_id" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <!-- WINDOW ACTION -->
    <record id="action_odosec_backup" model="ir.actions.act_window">
      <field name="name">Backup Manager</field>
      <field name="res_model">odosec.backup.manager</field>
      <field name="view_mode">list,form</field>
      <field name="context">{'create': False}</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">No backups yet.</p>
        <p>Use the <b>Trigger Backup</b> button to create an encrypted backup.</p>
      </field>
    </record>

  </data>
</odoo>
