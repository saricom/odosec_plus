<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">

    <!-- ═══════════════════════════════════════════════════════════════════
         AUDIT LOG — Complete write/unlink block for all non-superadmin users
         (Python-level immutability is the primary guard; this is defence-in-depth)
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="rule_audit_log_no_write_for_users" model="ir.rule">
      <field name="name">OdoSec: Audit Log — Block Write (All Users)</field>
      <field name="model_id" ref="model_odosec_audit_log"/>
      <!-- Domain (0,=,1) never matches any record → effectively blocks all writes -->
      <field name="domain_force">[(0, '=', 1)]</field>
      <field name="groups" eval="[(4, ref('base.group_user'))]"/>
      <field name="perm_read"   eval="False"/>
      <field name="perm_write"  eval="True"/>
      <field name="perm_create" eval="False"/>
      <field name="perm_unlink" eval="True"/>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         DELETION REQUEST — Analysts can only see/edit their own requests
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="rule_del_req_own_records" model="ir.rule">
      <field name="name">OdoSec: Deletion Request — Own Records (Analyst)</field>
      <field name="model_id" ref="model_odosec_deletion_request"/>
      <field name="domain_force">[('requested_by', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('odosec_plus.group_odosec_analyst'))]"/>
      <field name="perm_read"   eval="True"/>
      <field name="perm_write"  eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <!-- OdoSec Admin: sees all deletion requests -->
    <record id="rule_del_req_admin_all" model="ir.rule">
      <field name="name">OdoSec: Deletion Request — All Records (OdoSec Admin)</field>
      <field name="model_id" ref="model_odosec_deletion_request"/>
      <field name="domain_force">[(1, '=', 1)]</field>
      <field name="groups" eval="[(4, ref('odosec_plus.group_odosec_admin'))]"/>
      <field name="perm_read"   eval="True"/>
      <field name="perm_write"  eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         BACKUP — Viewers cannot see backup records at all
         (Backup data is restricted to OdoSec Admin and System Admin only)
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="rule_backup_viewer_no_access" model="ir.rule">
      <field name="name">OdoSec: Backup — No Access for plain Viewers</field>
      <field name="model_id" ref="model_odosec_backup_manager"/>
      <field name="domain_force">[(0, '=', 1)]</field>
      <field name="groups" eval="[(4, ref('odosec_plus.group_odosec_viewer'))]"/>
      <field name="perm_read"   eval="True"/>
      <field name="perm_write"  eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="True"/>
    </record>

    <!-- OdoSec Admin: can see/create/edit backups, but NOT download (controller enforces group_system) -->
    <record id="rule_backup_odosec_admin_access" model="ir.rule">
      <field name="name">OdoSec: Backup — Full Access (OdoSec Admin)</field>
      <field name="model_id" ref="model_odosec_backup_manager"/>
      <field name="domain_force">[(1, '=', 1)]</field>
      <field name="groups" eval="[(4, ref('odosec_plus.group_odosec_admin'))]"/>
      <field name="perm_read"   eval="True"/>
      <field name="perm_write"  eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         SECURITY SCAN — Analysts see all scans they triggered
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="rule_scan_own" model="ir.rule">
      <field name="name">OdoSec: Security Scan — Own Scans (Analyst)</field>
      <field name="model_id" ref="model_odosec_security_scan"/>
      <field name="domain_force">[('triggered_by', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('odosec_plus.group_odosec_analyst'))]"/>
      <field name="perm_read"   eval="True"/>
      <field name="perm_write"  eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_scan_admin_all" model="ir.rule">
      <field name="name">OdoSec: Security Scan — All Scans (OdoSec Admin)</field>
      <field name="model_id" ref="model_odosec_security_scan"/>
      <field name="domain_force">[(1, '=', 1)]</field>
      <field name="groups" eval="[(4, ref('odosec_plus.group_odosec_admin'))]"/>
      <field name="perm_read"   eval="True"/>
      <field name="perm_write"  eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="True"/>
    </record>

  </data>
</odoo>
