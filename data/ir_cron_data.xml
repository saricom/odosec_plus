<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">

    <!-- Daily security scan -->
    <record id="ir_cron_odosec_daily_scan" model="ir.cron">
      <field name="name">OdoSec Plus: Daily Security Scan</field>
      <field name="model_id" ref="model_odosec_security_scan"/>
      <field name="state">code</field>
      <field name="code">model.action_run_scheduled_scan()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="numbercall">-1</field>
      <field name="active">True</field>
      <field name="user_id" ref="base.user_root"/>
    </record>

    <!-- Daily health dashboard refresh -->
    <record id="ir_cron_odosec_health_refresh" model="ir.cron">
      <field name="name">OdoSec Plus: Refresh Security Health Dashboard</field>
      <field name="model_id" ref="model_odosec_security_health"/>
      <field name="state">code</field>
      <field name="code">model.action_compute_health()</field>
      <field name="interval_number">6</field>
      <field name="interval_type">hours</field>
      <field name="numbercall">-1</field>
      <field name="active">True</field>
      <field name="user_id" ref="base.user_root"/>
    </record>

    <!-- Weekly backup cleanup -->
    <record id="ir_cron_odosec_backup_cleanup" model="ir.cron">
      <field name="name">OdoSec Plus: Cleanup Old Backup Files</field>
      <field name="model_id" ref="model_odosec_backup_manager"/>
      <field name="state">code</field>
      <field name="code">model.action_cleanup_old_backups()</field>
      <field name="interval_number">7</field>
      <field name="interval_type">days</field>
      <field name="numbercall">-1</field>
      <field name="active">True</field>
      <field name="user_id" ref="base.user_root"/>
    </record>

    <!-- Nightly audit log retention cleanup -->
    <record id="ir_cron_odosec_log_cleanup" model="ir.cron">
      <field name="name">OdoSec Plus: Archive Old Audit Logs</field>
      <field name="model_id" ref="model_odosec_audit_log"/>
      <field name="state">code</field>
      <field name="code">model.action_archive_old_logs()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="numbercall">-1</field>
      <field name="active">True</field>
      <field name="user_id" ref="base.user_root"/>
    </record>

    <!-- Rate limiter cleanup -->
    <record id="ir_cron_odosec_rate_cleanup" model="ir.cron">
      <field name="name">OdoSec Plus: Cleanup Expired Rate-Limit Records</field>
      <field name="model_id" ref="model_odosec_rate_limiter"/>
      <field name="state">code</field>
      <field name="code">model.cleanup_expired()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">hours</field>
      <field name="numbercall">-1</field>
      <field name="active">True</field>
      <field name="user_id" ref="base.user_root"/>
    </record>

  </data>
</odoo>
